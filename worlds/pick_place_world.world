        </visual>
        <pose>6.00587 0.298732 0 0 0 1.5708</pose>
      </link>
      <link name='Wall_20'>
        <collision name='Wall_20_Collision'>
          <pose>0 0 1.25 0 0 0</pose>
          <geometry><box><size>6 0.15 2.5</size></box></geometry>
        </collision>
        <visual name='Wall_20_Visual'>
          <pose>0 0 1.25 0 0 0</pose>
          <geometry><box><size>6 0.15 2.5</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <n>Gazebo/Bricks</n>
            </script>
          </material>
        </visual>
        <pose>3.08087 3.34873 0 0 0 3.14159</pose>
      </link>
    </model>

    <!-- Door -->
    <model name='door_model'>
      <pose>-0.71664 2.7166 0.026996 0 0 0</pose>
      <static>1</static>
      <link name='Door_1'>
        <collision name='Door_1_Collision'>
          <pose>0 0 1 0 0 0</pose>
