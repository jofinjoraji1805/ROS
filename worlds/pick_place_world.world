    <model name='green_cube'>
      <static>false</static>
      <pose>-0.91 1.5 0.175 0 0 0</pose>
      <link name='link'>
        <gravity>true</gravity>
        <kinematic>false</kinematic>
        <inertial>
          <mass>0.01</mass>
          <inertia>
            <ixx>0.0000015</ixx><iyy>0.0000015</iyy><izz>0.0000005</izz>
