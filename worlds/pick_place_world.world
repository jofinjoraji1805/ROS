        </collision>
        <visual name='Wall_18_Visual_1'>
          <pose>2.58986 0 1.25 0 0 0</pose>
          <geometry><box><size>0.820282 0.15 2.5</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <n>Gazebo/Bricks</n>
            </script>
          </material>
        </visual>
      </link>
      <link name='Wall_19'>
